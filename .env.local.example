# ---------------------------------------------------------------------------
# Environment variables (all OPTIONAL — the site runs and deploys without them)
# Copy to `.env.local` for local dev, or set in the Vercel dashboard for prod.
# ---------------------------------------------------------------------------

# Canonical site URL — used for metadata, Open Graph, sitemap & robots.
# Set this to your production domain on Vercel.
NEXT_PUBLIC_SITE_URL=https://baburam-adhikari.vercel.app

# --- Contact form ---
# The live contact form posts to Formspree (configured in components/Contact.tsx)
# and needs NO env vars. The variables below only apply to the optional
# server-side alternative at app/api/contact/route.ts (Resend email).
RESEND_API_KEY=
RESEND_FROM_EMAIL=Portfolio <onboarding@resend.dev>
CONTACT_TO_EMAIL=psnbabu5@gmail.com
